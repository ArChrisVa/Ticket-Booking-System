# Template for services/auth/.env — copy this to ".env" and fill in real values.
# The .env file itself is gitignored; this .example IS committed so others know what
# variables the service needs (without leaking the real secret).
#
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
